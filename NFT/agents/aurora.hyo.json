  "pipeline": {
    "entrypoint": "newsletter.sh",
    "stages": [
      {
        "name": "gather",
        "script": "gather.py",
        "output": "~/Documents/Projects/Kai/intelligence/YYYY-MM-DD.jsonl"
      },
      {
        "name": "pre-context",
        "script": "../kai/ra_context.py",
        "output": "~/Documents/Projects/Hyo/kai/research/.context.md",
        "purpose": "Match today's gather records against the persistent archive, load prior takes, trend pulse, and lab library into a context block that synthesize prepends to its prompt."
      },
      {
        "name": "synthesize",
        "script": "synthesize.py",
        "output": "~/Documents/Projects/Hyo/newsletters/YYYY-MM-DD.md",
        "backends": ["xai:grok-4-fast", "anthropic:claude-sonnet-4-5", "bundle"]
      },
      {
        "name": "render",
        "script": "render.py",
        "output": "~/Documents/Projects/Hyo/newsletters/YYYY-MM-DD.html"
      },
      {
        "name": "archive",
        "script": "../kai/ra_archive.py",
        "output": "~/Documents/Projects/Hyo/kai/research/{entities,topics,lab,index.md,trends.md}",
        "purpose": "Parse the rendered brief's YAML frontmatter (entities/topics/lab_items), upsert per-entity timelines, update lab notes, rebuild master index and rolling trend report. Idempotent per date."
      }
    ],
    "schedule": "0 3 * * *",
    "scheduleTimezone": "America/Denver",
    "runtime": "python3-stdlib"
  },
