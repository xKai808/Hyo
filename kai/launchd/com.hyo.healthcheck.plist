<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.hyo.healthcheck</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-c</string>
    <string>source ~/.zprofile 2>/dev/null; HYO_ROOT=$HOME/Documents/Projects/Hyo bash $HOME/Documents/Projects/Hyo/kai/queue/healthcheck.sh</string>
  </array>
  <key>StartInterval</key>
  <integer>900</integer>
  <key>StandardOutPath</key>
  <string>/tmp/hyo-healthcheck.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/hyo-healthcheck.err</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>TZ</key>
    <string>America/Denver</string>
    <key>HYO_ROOT</key>
    <string>/Users/kai/Documents/Projects/Hyo</string>
  </dict>
</dict>
</plist>
